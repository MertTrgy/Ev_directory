<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
          http://www.liquibase.org/xml/ns/dbchangelog
          http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.24.xsd">

    <changeSet id="001_init_01" author="mert">
        <preConditions onFail="MARK_RAN" onError="HALT">
            <not>
                <tableExists tableName="evdb_vehicle_raw"/>
            </not>
        </preConditions>

        <sql dbms="postgresql">CREATE EXTENSION IF NOT EXISTS pgcrypto;</sql>

        <createTable tableName="evdb_vehicle_raw">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" primaryKeyName="pk_evdb_vehicle_raw" nullable="false"/>
            </column>
            <column name="source_name" type="VARCHAR(100)" defaultValue="open-ev-data-api">
                <constraints nullable="false"/>
            </column>
            <column name="source_vehicle_id" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="vehicle_slug" type="VARCHAR(255)"/>
            <column name="vehicle_name" type="VARCHAR(500)"/>
            <column name="market" type="VARCHAR(50)" defaultValue="global">
                <constraints nullable="false"/>
            </column>
            <column name="payload_hash" type="VARCHAR(64)">
                <constraints nullable="false"/>
            </column>
            <column name="payload" type="JSONB">
                <constraints nullable="false"/>
            </column>
            <column name="raw_source_url" type="TEXT"/>
            <column name="first_seen_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="last_seen_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addUniqueConstraint
                tableName="evdb_vehicle_raw"
                columnNames="source_name, source_vehicle_id, market"
                constraintName="uq_evdb_vehicle_source_market"/>

        <createIndex tableName="evdb_vehicle_raw" indexName="ix_evdb_vehicle_raw_vehicle_slug">
            <column name="vehicle_slug"/>
        </createIndex>

        <createIndex tableName="evdb_vehicle_raw" indexName="ix_evdb_vehicle_raw_vehicle_name">
            <column name="vehicle_name"/>
        </createIndex>

        <createIndex tableName="evdb_vehicle_raw" indexName="ix_evdb_vehicle_raw_market">
            <column name="market"/>
        </createIndex>

        <rollback>
            <dropTable tableName="evdb_vehicle_raw"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
