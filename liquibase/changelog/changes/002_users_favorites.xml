<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
          http://www.liquibase.org/xml/ns/dbchangelog
          http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.24.xsd">

    <changeSet id="002_users_01" author="mert">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="users"/></not>
        </preConditions>
        <createTable tableName="users">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" primaryKeyName="pk_users" nullable="false"/>
            </column>
            <column name="email" type="VARCHAR(255)">
                <constraints nullable="false" unique="true" uniqueConstraintName="uq_users_email"/>
            </column>
            <column name="password_hash" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="role" type="VARCHAR(50)" defaultValue="user">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <rollback><dropTable tableName="users"/></rollback>
    </changeSet>

    <changeSet id="002_favorites_01" author="mert">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="favorites"/></not>
        </preConditions>
        <createTable tableName="favorites">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" primaryKeyName="pk_favorites" nullable="false"/>
            </column>
            <column name="user_id" type="BIGINT">
                <constraints nullable="false"
                    foreignKeyName="fk_favorites_user"
                    references="users(id)"
                    deleteCascade="true"/>
            </column>
            <column name="vehicle_id" type="BIGINT">
                <constraints nullable="false"
                    foreignKeyName="fk_favorites_vehicle"
                    references="ev_vehicle_raw(id)"
                    deleteCascade="true"/>
            </column>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addUniqueConstraint
            tableName="favorites"
            columnNames="user_id, vehicle_id"
            constraintName="uq_favorite_user_vehicle"/>
        <createIndex tableName="favorites" indexName="ix_favorites_user_id">
            <column name="user_id"/>
        </createIndex>
        <rollback><dropTable tableName="favorites"/></rollback>
    </changeSet>

</databaseChangeLog>
